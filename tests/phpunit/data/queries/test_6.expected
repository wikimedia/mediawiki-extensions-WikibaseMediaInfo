{
    "bool": {
        "must": [
            {
                "match_none": {}
            }
        ],
        "filter": [
            {
                "bool": {
                    "must": [
                        {
                            "match": {
                                "template": {
                                    "query": "Template:foo"
                                }
                            }
                        },
                        {
                            "terms": {
                                "namespace": [
                                    0
                                ]
                            }
                        }
                    ],
                    "must_not": [
                        {
                            "term": {
                                "page_type": "redirect"
                            }
                        }
                    ]
                }
            }
        ]
    }
}